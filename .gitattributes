# Keep LF on shell scripts and world/launch files regardless of host
*.sh           text eol=lf
*.bash         text eol=lf
*.py           text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.world        text eol=lf
*.launch.py    text eol=lf
*.xml          text eol=lf
*.msg          text eol=lf
*.srv          text eol=lf
